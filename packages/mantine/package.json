{
  "name": "@ai-react-markdown/mantine",
  "version": "1.2.8",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@ai-react-markdown/core": "^1.2.8",
    "@mantine/code-highlight": "^8.3.17",
    "@mantine/core": "^8.3.17",
    "highlight.js": "^11.11.1",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@ai-react-markdown/core": "workspace:*",
    "@mantine/code-highlight": "^8.3.18",
    "@mantine/core": "^8.3.18",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "esbuild-sass-plugin": "^3.7.0",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.17.23",
    "postcss": "^8.5.8",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "deep-parse-json": "^2.0.0",
    "mermaid": "^11.14.0"
  }
}
